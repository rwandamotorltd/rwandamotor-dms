{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=rwandamotordms;Username=rwandamotor_api;Password=${DB_PASSWORD}"
  },
  "Jwt": {
    "Key": "${JWT_SECRET}",
    "Issuer": "https://api.rwandamotor.com",
    "Audience": "https://app.rwandamotor.com",
    "ExpiryHours": "8"
  },
  "Email": {
    "Host": "${EMAIL_HOST}",
    "Port": 587,
    "Username": "${EMAIL_USERNAME}",
    "Password": "${EMAIL_PASSWORD}",
    "EnableSsl": true,
    "FromAddress": "noreply@rwandamotor.com",
    "FromName": "Rwanda Motor DMS",
    "AlertRecipient": "${EMAIL_ALERT_RECIPIENT}"
  },
  "AllowedOrigins": [
    "https://app.rwandamotor.com"
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
