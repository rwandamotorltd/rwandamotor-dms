# /etc/rwandamotor/api.env
# Copy to /etc/rwandamotor/api.env on the server and fill in real values.
# chmod 600 /etc/rwandamotor/api.env
# chown rwandamotor:rwandamotor /etc/rwandamotor/api.env

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=rwandamotordms;Username=rwandamotor_api;Password=CHANGE_ME

Jwt__Key=CHANGE_ME_USE_A_LONG_RANDOM_STRING_MIN_32_CHARS
Jwt__Issuer=https://api.rwandamotor.com
Jwt__Audience=https://app.rwandamotor.com
Jwt__ExpiryHours=8
